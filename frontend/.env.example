# =============================================================
# eGramSabha — Frontend Environment Variables
# =============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================

REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_BACKEND_URL=http://localhost:5000

# Infrastructure provider: "JIO" | "GCP"
REACT_APP_INFRA=JIO

# API Gateway key (optional — enables x-api-key header on all API requests)
# REACT_APP_API_GATEWAY_KEY=your-api-gateway-key
